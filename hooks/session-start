#!/usr/bin/env bash
# SessionStart hook for ops plugin
# Injects skill routing context so Claude knows when to suggest ops skills.

set -euo pipefail

# Derive plugin root from hook location if not set by plugin system.
# Resolve symlinks so this works even if hooks/ is symlinked.
if [[ -z "${CLAUDE_PLUGIN_ROOT:-}" ]]; then
    _source="${BASH_SOURCE[0]}"
    if command -v realpath &>/dev/null; then
        _source="$(realpath "$_source")"
    fi
    CLAUDE_PLUGIN_ROOT="$(cd "$(dirname "$_source")/.." && pwd)"
    unset _source
fi
export PATH="${CLAUDE_PLUGIN_ROOT}/scripts:${PATH}"

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

CONTEXT="$(cat "${CLAUDE_PLUGIN_ROOT}/data/bootstrap-context.md")"

escaped=$(escape_for_json "$CONTEXT")

cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${escaped}"
  }
}
EOF

exit 0
